# Django secret key used for signing cookies and security-related values
DJANGO_SECRET_KEY=change-me

# Enable debug mode for local development
DJANGO_DEBUG=true

# Comma-separated hosts allowed to serve the application
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL database name
POSTGRES_DB=card_generator

# PostgreSQL user
POSTGRES_USER=card_generator

# PostgreSQL password
POSTGRES_PASSWORD=card_generator

# PostgreSQL host. Use 127.0.0.1 when the app runs locally
POSTGRES_HOST=127.0.0.1

# PostgreSQL port exposed by Docker Compose
POSTGRES_PORT=5432
